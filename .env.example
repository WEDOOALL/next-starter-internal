# =============================================================================
# next-starter-internal — .env TEMPLATE
# =============================================================================
# Copy to `.env.local` (gitignored) and fill values.
# In production, all values are injected by FORGE from Infisical → Coolify.

# ─── Supabase (self-hosted via supabase-internal.wedooall.com) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase-internal.wedooall.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
SUPABASE_SCHEMA=<app-slug>            # dedicated schema in supabase-internal Postgres
DATABASE_URL=postgresql://user:password@host:5432/db?schema=<app-slug>

# ─── Cloudflare Access (production) ───────────────────────────────────────────
# CF_ACCESS_TEAM_DOMAIN=wedooall.cloudflareaccess.com

# ─── Observability — Sentry ───────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
SENTRY_AUTH_TOKEN=sntryu_xxx          # build-time only — sourcemap upload

# ─── Observability — PostHog Cloud EU ─────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Email — Gmail Workspace SMTP (transactional) ─────────────────────────────
# Pattern "Send mail as alias" : auth with primary, send with alias
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=primary@wedooall.com         # account that owns the app password
# SMTP_PASSWORD=                         # 16-char app password, no spaces
# SMTP_FROM=WEDOOALL <noreply@wedooall.com>

# ─── Premium UI licenses (read from user env on dev machine) ──────────────────
# ACETERNITY_LICENSE  ← already set as user env var on Emmanuel's machine
# MOTION_PLUS_LICENSE ← already set as user env var on Emmanuel's machine

# ─── Dev only — used when running locally without CF Access ───────────────────
MOCK_OPERATOR_EMAIL=dev@wedooall.com
NODE_ENV=development
